    # Replace date placeholder
    local today=$(date +"%d %B %Y")
    sed -i "s/{{DATE}}/$today/" "$file"
    
    log_info "Created: $file"
    echo ""
    echo -e "Edit this file with your content, then run:"
    echo -e "  ${GREEN}wm build $slug${NC}"
}

# Simple markdown to HTML converter for WebModerne style
markdown_to_html() {
    local input="$1"
    local title="$2"
    local date="$3"
    local tags="$4"
    local description="$5"
    
    # Read markdown content
    local content=$(cat "$input")
    
    # Remove frontmatter
    content=$(echo "$content" | sed '1,/^---$/d')
    
    # Convert markdown to HTML (simplified)
    local html_body=""
    
    # Process line by line for basic markdown
    local in_list=0
    local in_table=0
    
    while IFS= read -r line || [ -n "$line" ]; do
        # Headers
        if [[ "$line" =~ ^#\ (.+)$ ]]; then
            html_body+="        <h1>${BASH_REMATCH[1]}</h1>\n"
        elif [[ "$line" =~ ^##\ (.+)$ ]]; then
            html_body+="        <h2>${BASH_REMATCH[1]}</h2>\n"
        elif [[ "$line" =~ ^###\ (.+)$ ]]; then
            html_body+="        <h3>${BASH_REMATCH[1]}</h3>\n"
        # Code blocks
        elif [[ "$line" =~ ^\`\`\`$ ]]; then
            if [ $in_list -eq 1 ]; then
                html_body+="        </ul>\n"
                in_list=0
            fi
            html_body+="        <div class=\"cli-illustration\">\n"
        # List items
        elif [[ "$line" =~ ^-\ \[\?]\ (.+)$ ]]; then
            if [ $in_list -eq 0 ]; then
                html_body+="        <ul>\n"
                in_list=1
            fi
            html_body+="          <li>✅ ${BASH_REMATCH[1]}</li>\n"
        elif [[ "$line" =~ ^-\ (.+)$ ]]; then
            if [ $in_list -eq 0 ]; then
                html_body+="        <ul>\n"
                in_list=1
            fi
            html_body+="          <li>${BASH_REMATCH[1]}</li>\n"
        # Bold
        elif [[ "$line" =~ \*\*(.+)\*\* ]]; then
            line=$(echo "$line" | sed 's/\*\*\([^*]*\)\*\*/<strong>\1<\/strong>/g')
            html_body+="        <p>$line</p>\n"
        # Regular paragraphs
        elif [[ -n "$line" && ! "$line" =~ ^[[:space:]]*$ ]]; then
            # Check for pipe in line (potential table)
            if [[ "$line" =~ ^\| ]]; then
                if [ $in_table -eq 0 ]; then
                    html_body+="        <table>\n"
                    in_table=1
                fi
                # Skip separator line
                if [[ ! "$line" =~ ^\|-+ ]]; then
                    html_body+="          <tr>\n"
                    # Split by pipe and create cells
                    IFS='|' read -ra cells <<< "$line"
                    for cell in "${cells[@]}"; do
                        cell=$(echo "$cell" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//') # trim
                        if [ -n "$cell" ]; then
                            if [[ "$line" =~ ^\|.*\|.*\|.*$ && ! "$line" =~ ^\|-+ ]]; then
                                html_body+="            <td>$cell</td>\n"
                            fi
                        fi
                    done
                    html_body+="          </tr>\n"
                fi
            else
                if [ $in_table -eq 1 ]; then
                    html_body+="        </table>\n"
                    in_table=0
                fi
                if [ $in_list -eq 1 ]; then
                    html_body+="        </ul>\n"
                    in_list=0
                fi
                # Convert links [text](url)
                line=$(echo "$line" | sed 's/\[\([^]]*\)\](\([^)]*\))/<a href="\2" style="color: #db1a1a;">\1<\/a>/g')
                # Convert inline code
                line=$(echo "$line" | sed 's/`\([^`]*\)`/<code style="background: #0a0a4a; padding: 2px 6px; border-radius: 3px;">\1<\/code>/g')
                html_body+="        <p>$line</p>\n"
            fi
        else
            if [ $in_list -eq 1 ]; then
                html_body+="        </ul>\n"
                in_list=0
            fi
            if [ $in_table -eq 1 ]; then
                html_body+="        </table>\n"
                in_table=0
            fi
        fi
    done <<< "$content"
    
    # Close any open tags
    if [ $in_list -eq 1 ]; then
        html_body+="        </ul>\n"
    fi
    if [ $in_table -eq 1 ]; then
        html_body+="        </table>\n"
    fi
    
    # Generate tags HTML
    local tags_html=""
    IFS=',' read -ra tag_array <<< "$tags"
    for tag in "${tag_array[@]}"; do
        tag=$(echo "$tag" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr -d '[]"')
        tags_html+="<span style=\"color: #db1a1a;\">#$tag</span> "
    done
    
    # Build full HTML
    cat << HTML
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$title - WebModerne</title>
  <meta name="description" content="$description">
  <meta name="author" content="Angel - WebModerne">
  <link rel="icon" type="image/png" href="/favicon.ico">
  
  <style>
    :root {
      --bg-color: $BG_COLOR;
      --accent-color: $ACCENT_COLOR;
      --text-color: $TEXT_COLOR;
      --code-bg: $CODE_BG;
      --border-color: $BORDER_COLOR;
    }
    * { box-sizing: border-box; }
    body {
      background-color: var(--bg-color);
      color: var(--text-color);
      font-family: 'Courier New', 'Consolas', 'Monaco', monospace;
      line-height: 1.6;
      margin: 0;
      padding: 0;
    }
    .container { max-width: 900px; margin: 0 auto; padding: 20px; }
    .header {
      border-bottom: 2px solid var(--accent-color);
      padding: 30px 0;
      margin-bottom: 40px;
    }
    .header h1 {
      color: var(--accent-color);
      font-size: 2.5em;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    .header .subtitle {
      color: #aaa;
      font-size: 1.1em;
      margin-top: 10px;
    }
    .nav { margin: 20px 0; }
    .nav a {
      color: var(--text-color);
      text-decoration: none;
      margin-right: 20px;
      padding: 8px 16px;
      border: 1px solid var(--accent-color);
      border-radius: 4px;
      transition: all 0.3s ease;
      display: inline-block;
    }
    .nav a:hover {
      background-color: var(--accent-color);
