    table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
    }
    th, td {
      border: 1px solid var(--border-color);
      padding: 10px;
      text-align: left;
    }
    th {
      background: var(--code-bg);
      color: var(--accent-color);
    }
    .footer {
      margin-top: 60px;
      padding-top: 20px;
      border-top: 1px solid var(--border-color);
      text-align: center;
      color: #666;
      font-size: 0.9em;
    }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }
    @media (max-width: 768px) {
      .container { padding: 15px; }
      .header h1 { font-size: 1.8em; }
      .nav a { display: block; margin-bottom: 10px; }
      .post-content { padding: 20px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="header">
      <h1>WebModerne</h1>
      <div class="subtitle">L'IA expliquée simplement aux non-techniques</div>
    </header>
    
    <nav class="nav">
      <a href="/">Accueil</a>
      <a href="/about.html">À Propos</a>
      <a href="/posts/">Articles</a>
    </nav>
    
    <main>
      <article class="post-content">
        <h1>$title</h1>
        <div class="date">Publié le $date • Tags: $tags_html</div>
        
$html_body
        
        <hr style="border: 1px solid var(--border-color); margin: 30px 0;">
        
        <div style="margin-top: 40px; text-align: center;">
          <a href="/posts/" style="color: #db1a1a;">← Retour aux articles</a>
        </div>
      </article>
    </main>
    
    <footer class="footer">
      <p>&copy; 2026 WebModerne - Tous droits réservés</p>
