# Convert markdown content to HTML
convert_markdown_to_html() {
    local content="$1"
    local html=""
    local in_code_block=0
    local in_list=0
    local in_table=0
    local table_is_header=1
    
    # Process line by line
    while IFS= read -r line || [ -n "$line" ]; do
        
        # Code block toggle
        if [[ "$line" == '```' ]]; then
            # Close any open structures
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            [ $in_table -eq 1 ] && { html+="        </table>\n"; in_table=0; }
            
            if [ $in_code_block -eq 0 ]; then
                html+="        <div class=\"cli-illustration\">\n"
                in_code_block=1
            else
                html+="        </div>\n"
                in_code_block=0
            fi
            continue
        fi
        
        # Inside code block - output as CLI lines
        if [ $in_code_block -eq 1 ]; then
            line=$(echo "$line" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g')
            if [[ "$line" == \$* ]]; then
                html+="          <div class=\"prompt\">$line</div>\n"
            elif [[ "$line" == ✓* ]]; then
                html+="          <div class=\"agent\">$line</div>\n"
            elif [[ "$line" == \>* ]]; then
                html+="          <div class=\"output\">$line</div>\n"
            elif [ -n "$line" ]; then
                html+="          <div class=\"output\">$line</div>\n"
            fi
            continue
        fi
        
        # Skip pure separator lines
        if [[ "$line" =~ ^---+$ ]]; then
            continue
        fi
        
        # Empty line - close open structures
        if [[ -z "$line" || "$line" =~ ^[[:space:]]*$ ]]; then
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            [ $in_table -eq 1 ] && { html+="        </table>\n"; in_table=0; }
            continue
        fi
        
        # H1 headers (# Title)
        if [[ "$line" =~ ^#\ (.+)$ ]]; then
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            [ $in_table -eq 1 ] && { html+="        </table>\n"; in_table=0; }
            html+="        <h1>${BASH_REMATCH[1]}</h1>\n"
            continue
        fi
        
        # H2 headers (## Title)
        if [[ "$line" =~ ^##\ (.+)$ ]]; then
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            [ $in_table -eq 1 ] && { html+="        </table>\n"; in_table=0; }
            html+="        <h2>${BASH_REMATCH[1]}</h2>\n"
            continue
        fi
        
        # H3 headers (### Title)
        if [[ "$line" =~ ^###\ (.+)$ ]]; then
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            [ $in_table -eq 1 ] && { html+="        </table>\n"; in_table=0; }
            html+="        <h3>${BASH_REMATCH[1]}</h3>\n"
            continue
        fi
        
        # Table rows (lines starting with |)
        if [[ "$line" == \|* ]]; then
            [ $in_list -eq 1 ] && { html+="        </ul>\n"; in_list=0; }
            
            # Skip table separator line
            if [[ "$line" =~ ^\|[\-\|[:space:]]+\|$ ]]; then
                continue
            fi
            
            if [ $in_table -eq 0 ]; then
                html+="        <table>\n"
                in_table=1
                table_is_header=1
            fi
            
            html+="          <tr>\n"
            IFS='|' read -ra cells <<< "$line"
            for cell in "${cells[@]}"; do
                cell=$(echo "$cell" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                if [ -n "$cell" ]; then
                    if [ $table_is_header -eq 1 ]; then
                        html+="            <th>$cell</th>\n"
                    else
                        html+="            <td>$cell</td>\n"
                    fi
                fi
            done
            html+="          </tr>\n"
            table_is_header=0
            continue
        fi
        
        # Not a table row - close table if open
        if [ $in_table -eq 1 ]; then
            html+="        </table>\n"
            in_table=0
        fi
        
        # List items (- ✅ text or - ❌ text or - text)
        if [[ "$line" =~ ^-\ (.*[^[:space:]].*)$ ]]; then
            if [ $in_list -eq 0 ]; then
                html+="        <ul>\n"
                in_list=1
            fi
            local item_text="${BASH_REMATCH[1]}"
            # Convert bold
            item_text=$(echo "$item_text" | sed 's/\*\*\([^*]*\)\*\*/<strong>\1<\/strong>/g')
            html+="          <li>$item_text</li>\n"
            continue
        fi
        
        # Not a list item - close list if open
        if [ $in_list -eq 1 ]; then
            html+="        </ul>\n"
            in_list=0
        fi
        
        # Regular paragraph - apply inline formatting
        # Links [text](url)
        line=$(echo "$line" | sed 's/\[\([^]]*\)\](\([^)]*\))/<a href="\2" style="color: #db1a1a;">\1<\/a>/g')
        # Bold **text**
        line=$(echo "$line" | sed 's/\*\*\([^*]*\)\*\*/<strong>\1<\/strong>/g')
        # Inline code `text`
        line=$(echo "$line" | sed 's/`\([^`]*\)`/<code style="background: #0a0a4a; padding: 2px 6px; border-radius: 3px;">\1<\/code>/g')
        
        # Blockquote > text
        if [[ "$line" == \>* ]]; then
            local quote_text="${line#\> }"
            html+="        <p style=\"color: #00ff00; font-family: monospace;\">$quote_text</p>\n"
        else
            html+="        <p>$line</p>\n"
        fi
        
    done <<< "$content"
    
    # Close any remaining open structures
    [ $in_list -eq 1 ] && html+="        </ul>\n"
    [ $in_table -eq 1 ] && html+="        </table>\n"
    [ $in_code_block -eq 1 ] && html+="        </div>\n"
    
    printf "%b" "$html"
}

# Build a post from markdown to HTML
cmd_build() {
    local slug="$1"
    
    if [ -z "$slug" ]; then
        log_error "Slug required. Usage: wm build <slug>"
        exit 1
    fi
    
    local md_file="$POSTS_MD_DIR/$slug.md"
    local html_file="$POSTS_HTML_DIR/$slug.html"
    
    if [ ! -f "$md_file" ]; then
        log_error "Markdown file not found: $md_file"
        echo "Create it first with: ${GREEN}wm create $slug${NC}"
        exit 1
    fi
    
    log_info "Building: $slug"
    
    # Extract frontmatter using grep and sed (handles French quotes)
    local title=$(grep "^title:" "$md_file" | sed 's/^title:[[:space:]]*"\(.*\)"$/\1/')
    local date=$(grep "^date:" "$md_file" | sed 's/^date:[[:space:]]*"\(.*\)"$/\1/')
    local tags=$(grep "^tags:" "$md_file" | sed 's/^tags:[[:space:]]*\(.*\)$/\1/')
    local description=$(grep "^description:" "$md_file" | sed 's/^description:[[:space:]]*"\(.*\)"$/\1/')
    
    # Remove frontmatter (content between first two --- lines)
    local content=$(awk '/^---$/{n++; next} n>=2' "$md_file")
    
    # Generate tags HTML
    local tags_html=""
    # Remove brackets and quotes, split by comma
    tags=$(echo "$tags" | tr -d '[]"' | tr ',' '\n')
    while IFS= read -r tag; do
        tag=$(echo "$tag" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [ -n "$tag" ]; then
            tags_html+="<span style=\"color: #db1a1a;\">#$tag</span> "
        fi
    done <<< "$tags"
    
    # Convert markdown to HTML
    local html_body=$(convert_markdown_to_html "$content")
    
    # Write complete HTML file
    {
        generate_html_header "$title" "$description" "$slug" "$date" "$tags_html"
        echo -e "$html_body"
        generate_html_footer
    } > "$html_file"
    
    log_info "Generated: $html_file"
    
    # Update index
    update_index "$slug" "$title" "$date" "$description"
    
    echo ""
    echo -e "Next step: ${GREEN}wm deploy${NC}"
}

# Update the posts index.html with new entry
update_index() {
    local slug="$1"
    local title="$2"
    local date="$3"
    local description="$4"
    
    # Format date for display (ensure proper format)
    local display_date="$date"
    
    # Create new post entry HTML
    local new_entry="        <li class=\"post-item\">\n          <h2><a href=\"/posts/$slug.html\">$title</a></h2>\n          <div class=\"date\">$display_date</div>\n          <div class=\"summary\">$description</div>\n        </li>\n"
    
    # Check if entry already exists
    if grep -q "href=\"/posts/$slug.html\"" "$INDEX_FILE"; then
        log_warn "Index already contains: $slug"
        return 0
    fi
    
    # Insert after the opening ul tag
    local temp_file=$(mktemp)
    awk -v entry="$new_entry" '
        /<ul class="post-list">/ {
            print
            printf entry
            next
        }
        {print}
    ' "$INDEX_FILE" > "$temp_file"
    
    mv "$temp_file" "$INDEX_FILE"
    
    log_info "Updated index with: $title"
}

# List all posts
cmd_list() {
    echo ""
    echo -e "${BLUE}Posts in posts-md/ (source):${NC}"
    echo "─────────────────────────────────────"
    
    if [ -d "$POSTS_MD_DIR" ]; then
        local found=0
        for f in "$POSTS_MD_DIR"/*.md; do
            if [ -f "$f" ]; then
                local slug=$(basename "$f" .md)
                local title=$(grep "^title:" "$f" 2>/dev/null | sed 's/^title:[[:space:]]*"\(.*\)"$/\1/' || echo "Untitled")
                echo -e "  ${GREEN}✓${NC} $slug - $title"
                found=1
            fi
        done
        if [ $found -eq 0 ]; then
            echo "  (no posts yet)"
        fi
    else
        echo "  (no posts yet)"
    fi
    
    echo ""
    echo -e "${BLUE}Posts in posts/ (published):${NC}"
    echo "─────────────────────────────────────"
    
    if [ -d "$POSTS_HTML_DIR" ]; then
        local found=0
        for f in "$POSTS_HTML_DIR"/*.html; do
            if [ -f "$f" ]; then
                local fname=$(basename "$f")
                if [ "$fname" != "index.html" ]; then
                    local slug=$(basename "$f" .html)
                    echo -e "  ${GREEN}✓${NC} $slug.html"
                    found=1
                fi
            fi
        done
        if [ $found -eq 0 ]; then
            echo "  (no posts published)"
        fi
    else
        echo "  (no posts published)"
    fi
    echo ""
}

# Deploy to GitHub Pages
cmd_deploy() {
    log_info "Deploying to GitHub Pages..."
    
    cd "$BLOG_DIR"
    
    # Check for changes
    if [ -z "$(git status --porcelain)" ]; then
        log_warn "No changes to commit"
        exit 0
    fi
    
    # Show what will be committed
    echo ""
    git status --short
    echo ""
    
    # Add all changes
    git add -A
    
    # Commit
    local timestamp=$(date +"%Y-%m-%d %H:%M")
    git commit -m "Deploy blog update - $timestamp"
    
    # Push
    git push origin main
    
    log_info "Deployed successfully!"
    echo ""
    echo -e "Your blog will be live at: ${BLUE}https://blog.webmoderne.com${NC}"
}

# Main command router
case "${1:-help}" in
    create)
        cmd_create "$2"
        ;;
    build)
        cmd_build "$2"
        ;;
    list)
        cmd_list
        ;;
    deploy)
        cmd_deploy
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        log_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
