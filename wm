    }
    .terminal-box {
      background: var(--code-bg);
      border: 1px solid var(--border-color);
      border-left: 4px solid var(--accent-color);
      padding: 20px;
      margin: 20px 0;
      border-radius: 0 8px 8px 0;
    }
    .terminal-box h3 {
      color: var(--accent-color);
      margin-top: 0;
    }
    .post-content {
      background: var(--code-bg);
      padding: 30px;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    .post-content h1 {
      color: var(--accent-color);
      border-bottom: 2px solid var(--accent-color);
