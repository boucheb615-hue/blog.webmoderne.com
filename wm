#!/bin/bash

# wm - WebModerne Blog CLI
# Create, build, and deploy blog posts for webmoderne.com
# Portable: works from any directory, detects blog root automatically

set -e

# Detect blog directory (follow symlinks to find actual script location)
get_script_dir() {
    local source="${BASH_SOURCE[0]}"
    while [ -h "$source" ]; do
        local dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    echo "$(cd -P "$(dirname "$source")" && pwd)"
}

SCRIPT_DIR="$(get_script_dir)"
BLOG_DIR="$SCRIPT_DIR"
POSTS_MD_DIR="$BLOG_DIR/posts-md"
POSTS_HTML_DIR="$BLOG_DIR/posts"
INDEX_FILE="$POSTS_HTML_DIR/index.html"

# WebModerne brand colors
BG_COLOR="#090935"
ACCENT_COLOR="#db1a1a"
TEXT_COLOR="#ffffff"
CODE_BG="#0a0a4a"
BORDER_COLOR="#1a1a5a"

# Colors for CLI output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_help() {
    echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║${NC}  ${ACCENT_COLOR}wm${NC} - WebModerne Blog CLI               ${BLUE}║${NC}"
    echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"
    echo ""
    echo "Usage: wm <command> [options]"
    echo ""
    echo "Commands:"
    echo "  create <slug>     Create a new markdown post template"
    echo "  build <slug>      Convert markdown to HTML and publish"
    echo "  list              Show all posts"
    echo "  deploy            Commit and push to GitHub Pages"
    echo "  help              Show this help message"
    echo ""
    echo "Examples:"
    echo "  wm create mon-article"
    echo "  wm build mon-article"
    echo "  wm deploy"
    echo ""
    echo "Blog directory: $BLOG_DIR"
}

log_info() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# Create a new markdown post template
cmd_create() {
    local slug="$1"
    
    if [ -z "$slug" ]; then
        log_error "Slug required. Usage: wm create <slug>"
        exit 1
    fi
    
    local file="$POSTS_MD_DIR/$slug.md"
    
    if [ -f "$file" ]; then
        log_error "Post already exists: $slug"
        exit 1
    fi
    
    local today=$(date +"%d %B %Y")
    
    cat > "$file" << TEMPLATE
---
title: "Titre de l'article"
date: "$today"
tags: ["ia", "vulgarisation", "recherche"]
description: "Description courte en une phrase"
---

# Le Problème

[Expliquer le problème que le rapport de recherche adresse]

## La Question en Termes Simples

[Une analogie ou explication simple]

# La Solution (Ce qu'ont fait les chercheurs)

[Décrire la méthodologie]

## Leur Découverte

\`\`\`
\$ agent analyze --task=comprehension
> Testing...
> Result: [résultat]
✓ Agent IA a détecté [conclusion]
\`\`\`

[Interprétation des résultats]

# Pourquoi Ça Compte Pour Toi

### L'Impact Réel

**Avant** : [situation avant]

**Maintenant** : [situation maintenant]

**Pour toi** : [bénéfice concret]

### Concrètement :

- ✅ [Bénéfice 1]
- ✅ [Bénéfice 2]
- ✅ [Bénéfice 3]

# En Résumé

| Question | Réponse |
|----------|---------|
| [Question 1] | [Réponse 1] |
| [Question 2] | [Réponse 2] |
| [Question 3] | [Réponse 3] |

---

**Prochain article** : [Teaser du prochain article]

### Tu veux aller plus loin ?

Le rapport original : [Lien arXiv](https://arxiv.org) (en anglais, très technique)

Notre version : celle que tu viens de lire 😊
TEMPLATE

    log_info "Created: $file"
    echo ""
    echo -e "Edit this file with your content, then run:"
    echo -e "  ${GREEN}wm build $slug${NC}"
}

